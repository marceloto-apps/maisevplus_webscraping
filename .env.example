# ============================================================
# MaisEV+ WebScraping — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores
# NUNCA commite o arquivo .env no git!
# ============================================================

# --- PostgreSQL / TimescaleDB ---
DATABASE_URL=postgresql://usuario:senha@localhost:5432/maisevplus
DB_HOST=localhost
DB_PORT=5432
DB_NAME=maisevplus
DB_USER=usuario
DB_PASSWORD=senha
DB_POOL_MIN=5              # asyncpg pool min connections
DB_POOL_MAX=20             # asyncpg pool max connections (backfill: 20, prod: 10)

# --- Footystats API ---
# Key ilimitada — fonte primária de resultados e stats
FOOTYSTATS_API_KEY=sua_key_aqui

# --- The Odds API (5 contas free — 500 req/mês cada) ---
ODDS_API_KEY_1=sua_key_1
ODDS_API_KEY_2=sua_key_2
ODDS_API_KEY_3=sua_key_3
ODDS_API_KEY_4=sua_key_4
ODDS_API_KEY_5=sua_key_5

# --- API-Football (7 contas free — 100 req/dia cada) ---
API_FOOTBALL_KEY_1=sua_key_1
API_FOOTBALL_KEY_2=sua_key_2
API_FOOTBALL_KEY_3=sua_key_3
API_FOOTBALL_KEY_4=sua_key_4
API_FOOTBALL_KEY_5=sua_key_5
API_FOOTBALL_KEY_6=sua_key_6
API_FOOTBALL_KEY_7=sua_key_7

# --- Telegram Alertas ---
TELEGRAM_BOT_TOKEN=seu_bot_token
TELEGRAM_CHAT_ID=seu_chat_id

# --- Selenium / FlashScore ---
CHROME_DRIVER_PATH=         # Deixe vazio para uso automático via webdriver-manager
FLASHSCORE_HEADLESS=true    # false para debug visual

# --- Scheduler ---
TIMEZONE=America/Sao_Paulo

# --- Logging ---
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json             # json | text

# --- Backup OneDrive (via rclone) ---
RCLONE_REMOTE=onedrive                    # Nome do remote configurado via: rclone config
BACKUP_ONEDRIVE_PATH=maisevplus_backups   # Pasta de destino no OneDrive
BACKUP_LOCAL_RETENTION_DAYS=2             # Dias de retenção local (VPS)
BACKUP_ONEDRIVE_RETENTION_COUNT=5        # Qtd. de backups a manter no OneDrive
